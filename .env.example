NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Google Cloud Console > OAuth client (type "Web application") ; redirect URI autorisée :
# <SUPABASE_URL>/auth/v1/callback (local : http://127.0.0.1:54321/auth/v1/callback)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
OPENROUTER_API_KEY=
LLM_MODEL_RUBRIQUE=
LLM_MODEL_SECTIONNEMENT=
LLM_MODEL_CORRECTION_ERREURS=
LLM_MODEL_TRANSCRIPTION=
LLM_MODEL_FEYNMAN=
# app/api/cron (Vercel Cron, Bloc 6.4) : secret partagé, à définir aussi dans les
# variables d'environnement Vercel — Vercel envoie `Authorization: Bearer <valeur>`.
CRON_SECRET=
