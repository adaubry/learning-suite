DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/postgres
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Google Cloud Console > OAuth client (type "Web application") ; redirect URI autorisée :
# <domaine>/api/auth/callback/google (local : http://localhost:3000/api/auth/callback/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
OPENROUTER_API_KEY=
LLM_MODEL_RUBRIQUE=
LLM_MODEL_SECTIONNEMENT=
LLM_MODEL_CORRECTION_ERREURS=
LLM_MODEL_TRANSCRIPTION=
LLM_MODEL_FEYNMAN=
# app/api/cron (Vercel Cron, Bloc 6.4) : secret partagé, à définir aussi dans les
# variables d'environnement Vercel — Vercel envoie `Authorization: Bearer <valeur>`.
CRON_SECRET=
